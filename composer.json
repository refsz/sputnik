{
    "name": "refs/sputnik",
    "description": "Modern PHP TaskRunner with class-based tasks, Nette DI, and template engine",
    "type": "library",
    "license": "MIT",
    "keywords": ["task-runner", "cli", "automation", "build", "devops"],
    "homepage": "https://github.com/refsz/sputnik",
    "authors": [
        {
            "name": "Marcel Reuss",
            "email": "marcel@refs.media"
        }
    ],
    "support": {
        "issues": "https://github.com/refsz/sputnik/issues",
        "source": "https://github.com/refsz/sputnik"
    },
    "require": {
        "php": "^8.2",
        "nette/di": "^3.2",
        "nette/neon": "^3.4",
        "nette/utils": "^4.0",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "psr/log": "^3.0",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "dg/bypass-finals": "^1.9",
        "friendsofphp/php-cs-fixer": "^3.94",
        "humbug/box": "^4.7",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.3",
        "symfony/var-dumper": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Sputnik\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sputnik\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/sputnik"
    ],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.2.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
