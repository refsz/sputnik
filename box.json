{
    "alias": "sputnik.phar",
    "chmod": "0755",
    "compactors": [
        "KevinGH\\Box\\Compactor\\Php"
    ],
    "compression": "GZ",
    "directories": [
        "src"
    ],
    "files": [
        "vendor/autoload.php"
    ],
    "finder": [
        {
            "in": "vendor",
            "name": "*.php",
            "exclude": [
                "tests",
                "Tests",
                "test",
                "docs"
            ]
        },
        {
            "in": "vendor/symfony/console/Resources"
        }
    ],
    "replacements": {
        "@package_version@": "git-version"
    },
    "main": "bin/sputnik",
    "output": "build/sputnik.phar",
    "shebang": "#!/usr/bin/env php"
}
